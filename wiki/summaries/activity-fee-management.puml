@startuml 收费管理活动图
!theme plain
skinparam backgroundColor #FAFAFA
skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    FontSize 12
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F9A825
}
skinparam swimlane {
    BackgroundColor #F5F5F5
    BorderColor #9E9E9E
    FontSize 13
    FontStyle bold
}

title 教育培训机构收费管理活动图

' =============================================
' 流程一：学费收取流程
' =============================================
|教务人员|
start
:教务人员登录系统;
:选择目标学员;

|系统|
if (学员是否存在欠费?) then (是)
    :显示欠费信息;
    detach
else (否)
endif

:加载学员已报课程列表;
:选择需缴费课程;

if (是否享受优惠?) then (是)
    :应用优惠折扣;
else (否)
endif

:系统计算应缴费用;
:确认费用明细;

|教务人员|
:确认缴费金额;
:选择支付方式;

|系统|
if (支付方式?) then (现金)
    :记录现金收款;
else if (银行转账)
    :验证转账凭证;
else if (扫码支付)
    :调用支付网关;
    :等待支付结果;
endif

if (支付成功?) then (是)
    :更新学员缴费状态;
    :生成电子收据;
    :打印收据;
    :写入收费台账;
    :发送缴费成功通知;
    stop
else (否)
    :记录失败日志;
    :提示重新支付;
    detach
endif

' =============================================
' 流程二：退费流程
' =============================================
|学生/家长|
start
:提交退费申请;
:填写退费原因;
:上传相关证明材料;

|教务人员|
:接收退费申请;
:核实学员信息与缴费记录;

if (材料齐全?) then (是)
    :审核退费合理性;
    if (符合退费条件?) then (是)
        :核算应退金额;
        :填写审核意见;
        :提交财务审批;
    else (否)
        :驳回退费申请;
        :通知申请人;
        stop
    endif
else (否)
    :通知补充材料;
    stop
endif

|财务人员|
:接收退费审批任务;
:复核退费金额;

if (金额是否需要特殊审批?) then (是)
    :提交机构管理员审批;

    |机构管理员|
    :审批退费申请;
    if (审批通过?) then (是)
        :签字确认;
    else (否)
        :驳回至教务;
        stop
    endif

endif

|财务人员|
:执行退费操作;
:原路退款或现金退款;
:更新收费台账（退费记录）;
:生成退费凭证;
:打印退费收据;
:发送退费完成通知;
stop

' =============================================
' 流程三：欠费催缴流程
' =============================================
|系统|
start
:定时扫描欠费数据;
:筛选欠费学员列表;

while (遍历欠费学员) is (有欠费学员)
    :计算欠费金额与逾期天数;

    if (逾期天数?) then (≤ 7天)
        :生成一级催缴通知（温和提醒）;
    else if (≤ 30天)
        :生成二级催缴通知（正式催缴）;
    else (≤ 60天)
        :生成三级催缴通知（严重警告）;
    else (> 60天)
        :标记为坏账风险;
        :生成最终催缴函;
    endif

    :推送催缴通知给家长;

    |学生/家长|
    if (是否收到通知后缴费?) then (是)
        :前往缴费;
        |系统|
        :更新催缴状态为已缴费;
    else (否)
        |系统|
        :记录本次催缴跟进;
    endif

endwhile (无更多欠费学员)

|教务人员|
:查看催缴跟进记录;
:对长期欠费学员电话跟进;
:记录电话跟进结果;

|系统|
:生成欠费催缴报表;
stop

@enduml
